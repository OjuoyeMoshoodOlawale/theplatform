# ── Frontend Environment Variables ────────────────────────────
# Copy to .env and fill in your Paystack PUBLIC key (not secret!)
# The backend uses the secret key; frontend only needs the public key.

# Paystack public key — needed for inline payment popup
# Get from: https://dashboard.paystack.com/#/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
