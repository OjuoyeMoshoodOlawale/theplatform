# =============================================================
# EVENT PLATFORM (multi-tenant) — Environment Variables
# Copy this file to .env and fill in your values.
#
# ⚠️ SEPARATE DATABASE: this multi-tenant platform uses its OWN database
#    (event_platform), NOT the single-tenant MYS database (mys_platform).
#    Never point this at the MYS production DB — setup:tenant backfills and
#    restructures data. Keep them physically separate.
#
# REQUIRED (app will not start without these):
#   DB_HOST, DB_NAME, DB_USER, JWT_SECRET
# OPTIONAL (features disabled until set):
#   DB_PASS, PAYSTACK_*, SMTP_*, TERMII_*
# =============================================================

# ── Database (REQUIRED) — SEPARATE from MYS ───────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
# Platform DB — distinct from the single-tenant MYS "mys_platform" DB
DB_NAME=event_platform

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── JWT (REQUIRED) ────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_characters
JWT_EXPIRES_IN=8h

# ── Platform-default Paystack (OPTIONAL) ──────────────────────
# Used for any tenant that has NOT set its own keys in Settings.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=
PAYMENT_CALLBACK_URL=http://localhost:5173/ticket/verify

# ── Email / SMTP (OPTIONAL — used by all tenants) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_character_app_password
EMAIL_FROM=Event Platform <noreply@yourplatform.com>

# ── Termii SMS (OPTIONAL — used by all tenants) ───────────────
TERMII_API_KEY=
TERMII_SENDER_ID=Platform
TERMII_CHANNEL=generic
